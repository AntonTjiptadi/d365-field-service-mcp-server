# ============================================
# D365 MCP Server - TRIAL Environment Configuration
# ============================================
# IMPORTANT: This file contains sensitive credentials
# - DO NOT commit to Git
# - Add to .gitignore
# - Keep secure and private
# ============================================

# ============================================
# Azure AD Authentication
# ============================================
# Get these from Azure Portal → App Registrations → Your App

# Your Azure AD Tenant ID (GUID format)
# Find at: Azure Portal → Azure Active Directory → Overview → Tenant ID
TENANT_ID=00000000-0000-0000-0000-000000000000

# Application (Client) ID from your App Registration
# Find at: Azure Portal → App Registrations → Your App → Overview → Application (client) ID
CLIENT_ID=00000000-0000-0000-0000-000000000000

# Client Secret value (NOT the Secret ID)
# Find at: Azure Portal → App Registrations → Your App → Certificates & secrets
# NOTE: Copy the VALUE when you create it - you can't see it again later!
CLIENT_SECRET=your-client-secret-value-here

# ============================================
# Dynamics 365 Configuration
# ============================================

# Your D365 Trial Organization URL
# Format: https://orgXXXXXXXX.crm.dynamics.com
# Find at: Power Platform Admin Center → Environments → Your Trial → Environment URL
D365_URL=https://org12345678.crm.dynamics.com

# D365 API Scope (your org URL + /.default)
# This tells Azure AD what resource you're accessing
D365_SCOPE=https://org12345678.crm.dynamics.com/.default

# ============================================
# Environment Metadata
# ============================================

# Environment type identifier
ENVIRONMENT=trial

# Optional: Trial expiration date (for tracking)
TRIAL_EXPIRES=2025-02-15

# Optional: Notes
NOTES=D365 Field Service Trial Environment - Testing MCP Server

# ============================================
# Optional: Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable verbose output for troubleshooting
VERBOSE_MODE=false

# ============================================
# SETUP CHECKLIST
# ============================================
# Before using this file, ensure:
# ✓ App Registration created in Azure AD
# ✓ API Permissions added: Dynamics CRM → user_impersonation
# ✓ Admin Consent granted for API permissions
# ✓ Client Secret created and copied (you can't retrieve it later!)
# ✓ D365 Trial environment is active and accessible
# ✓ Test user has proper security roles in D365
# ============================================
